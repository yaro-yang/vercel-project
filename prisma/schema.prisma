// Prisma Schema - 万能导入系统

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DATABASE_URL")
}

// 运单表
model Order {
  id            String      @id @default(cuid())
  orderNo       String      @unique          // 系统订单号
  externalCode  String?                     // 外部编码（用户导入时填写的原始编号）
  
  // 寄件人信息
  senderName    String                      
  senderPhone   String?
  senderAddress String?
  
  // 收件人信息
  receiverName String
  receiverPhone String?
  receiverAddress String?
  
  // 物品信息
  quantity     Int?                        // 件数
  weight       Decimal?  @db.Decimal(10, 2) // 重量
  temperature  String?                     // 温层
  remark       String?                     // 备注
  
  // 金额
  totalAmount  Decimal?  @db.Decimal(12, 2)
  discount     Decimal?  @db.Decimal(12, 2)
  finalAmount  Decimal?  @db.Decimal(12, 2)
  
  // 状态
  status       OrderStatus @default(PENDING)
  
  // 来源信息
  source       String?                     // 导入来源标识
  templateId   String?                     // 使用的模板ID
  batchId      String?                     // 导入批次ID
  
  // 原始数据
  rawData      Json?                       
  
  // 时间戳
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
  
  // 关系
  template     Template?  @relation(fields: [templateId], references: [id])
  batch        ImportBatch? @relation(fields: [batchId], references: [id])
  
  @@index([orderNo])
  @@index([externalCode])
  @@index([status])
  @@index([receiverName])
  @@index([createdAt])
  @@index([batchId])
}

// 导入批次表
model ImportBatch {
  id            String      @id @default(cuid())
  filename      String                       // 原始文件名
  templateId    String?                      // 使用的模板
  templateName  String?                      // 模板名称（保存快照）
  
  // 统计
  totalCount    Int       @default(0)        // 总数
  successCount  Int       @default(0)        // 成功数
  failedCount   Int       @default(0)        // 失败数
  
  // 状态
  status        BatchStatus @default(PENDING)
  
  // 错误记录
  errors        Json?                        // 批量错误记录
  
  // 时间
  createdAt     DateTime  @default(now())
  completedAt   DateTime?
  
  // 关系
  orders        Order[]
  
  @@index([status])
  @@index([createdAt])
}

// 模板表
model Template {
  id          String   @id @default(cuid())
  name        String                     // 模板名称
  description String?                    // 模板描述
  type        TemplateType @default(CUSTOM)
  
  // 字段映射配置
  mappings    Json                       // { fieldKey: "Excel列名", ... }
  headers     Json?                      // 保存原始表头 [{original: "A列", mapped: "寄件人"}]
  
  // 文件类型
  fileType    FileType @default(EXCEL)
  
  // 状态
  isActive    Boolean  @default(true)
  isDefault   Boolean  @default(false)
  
  // 预设标识（用于内置模板）
  presetKey   String?  @unique            // 如 "standard", "express"
  
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  
  // 关系
  orders      Order[]
  
  @@index([type])
  @@index([isActive])
  @@index([presetKey])
}

// 枚举定义

enum OrderStatus {
  PENDING     // 待处理
  CONFIRMED   // 已确认
  PROCESSING  // 处理中
  SHIPPED     // 已发货
  COMPLETED   // 已完成
  CANCELLED   // 已取消
}

enum BatchStatus {
  PENDING     // 待处理
  PROCESSING  // 处理中
  COMPLETED   // 已完成
  FAILED      // 失败
}

enum TemplateType {
  STANDARD    // 标准订单
  EXPRESS     // 快递单
  WHOLESALE   // 批发单
  CUSTOM      // 自定义
}

enum FileType {
  EXCEL       // .xlsx/.xls
  CSV         // .csv
  JSON        // .json
}
